# Copy this file to .env and fill in your own values. Vite exposes only
# variables prefixed with VITE_ to the app, and reads them at startup
# (restart the dev server after changing).

# Contact form (src/components/ContactForm.jsx).
# Create a form at https://formspree.io and paste its endpoint here.
# If unset, a working default portfolio endpoint is used.
VITE_FORMSPREE_ENDPOINT=your_formspree_endpoint_here

# Privacy-friendly analytics (optional). Set to your site domain to enable
# a cookieless GoatCounter/Plausible-style pixel. Leave blank to disable.
VITE_ANALYTICS_DOMAIN=

# WhatsApp click-to-chat number in international format, digits only,
# e.g. 447123456789. Leave blank to keep the WhatsApp buttons disabled.
VITE_WHATSAPP_NUMBER=
